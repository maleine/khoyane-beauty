<%- include('partials/header') %>

<!-- ══════════════════════════════════════════
     HERO — image sans texte (nail-_XX_.jpg)
══════════════════════════════════════════ -->
<section class="page-hero">
  <div class="page-hero-overlay"></div>
  <img src="/images/nail-_21_.jpg" alt="Boutique Super Beauty Market" class="page-hero-bg"
       onerror="this.onerror=null;this.src='/images/nail-21.jpg'">
  <div class="page-hero-content text-center">
    <p class="section-pre gold">boutique</p>
    <h1 class="page-hero-title">NOS PRODUITS</h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb justify-content-center">
        <li class="breadcrumb-item"><a href="/" class="text-white">Accueil</a></li>
        <li class="breadcrumb-item active text-white-50">Produits</li>
      </ol>
    </nav>
  </div>
  <div class="page-hero-watermark">Super Beauty Market</div>
</section>

<!-- ══════════════════════════════════════════
     BARRE PANIER FIXE (apparaît quand items)
══════════════════════════════════════════ -->
<div id="cartBar" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:600;
  background:#fff;border-top:1px solid #e8dff0;
  box-shadow:0 -2px 12px rgba(45,31,69,0.10);padding:10px 0;">
  <div class="container d-flex justify-content-between align-items-center">
    <div style="display:flex;align-items:center;gap:12px;">
      <div style="position:relative;">
        <i class="bi bi-bag" style="font-size:1.4rem;color:#8860a8;"></i>
        <span id="cartCountBadge" style="position:absolute;top:-5px;right:-7px;background:#c94d9a;color:#fff;border-radius:50%;width:16px;height:16px;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;">0</span>
      </div>
      <div>
        <div style="font-size:10px;color:#aaa;letter-spacing:1px;text-transform:uppercase;">Panier</div>
        <div style="font-size:1rem;font-weight:700;color:#2d1f45;">
          <span id="cartTotalBar">0</span> <span style="font-size:11px;color:#999;">FCFA</span>
        </div>
      </div>
    </div>
    <button onclick="openModal()" style="background:#2d1f45;color:#fff;border:none;border-radius:8px;
      padding:10px 24px;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
      cursor:pointer;transition:background 0.2s;"
      onmouseover="this.style.background='#8860a8'"
      onmouseout="this.style.background='#2d1f45'">
      Voir mon panier →
    </button>
  </div>
</div>

<!-- ══════════════════════════════════════════
     SECTION PRINCIPALE
══════════════════════════════════════════ -->
<section class="py-5" style="background:#fdf9ff;padding-bottom:100px !important;">
  <div class="container">

    <!-- En-tête + badges paiement -->
    <div class="text-center mb-5">
      <p class="section-pre gold">sélection premium</p>
      <h2 class="section-title">COSMÉTIQUES & SOINS ONGLES</h2>
      <p class="text-muted" style="font-size:14px;max-width:580px;margin:12px auto 0;line-height:1.7;">
        Produits disponibles à l'achat. Payez par espèces, Wave, Orange Money ou virement bancaire.
      </p>

      <!-- Modes de paiement -->
      <div style="display:flex;justify-content:center;flex-wrap:wrap;gap:10px;margin-top:20px;">
        <div class="pay-chip"><span>💵</span> Espèces</div>
        <div class="pay-chip wave-chip">
          <img src="/images/wave-logo.webp" alt="Wave" style="height:16px;object-fit:contain;">
          Wave
        </div>
        <div class="pay-chip om-chip">
          <img src="/images/orange-money-logo.webp" alt="Orange Money" style="height:16px;object-fit:contain;">
          Orange Money
        </div>
        <div class="pay-chip"><span>🏦</span> Virement bancaire</div>
      </div>
    </div>

    <!-- Filtres -->
    <div class="produits-filters mb-4">
      <div class="produits-search-wrap">
        <i class="bi bi-search produits-search-icon"></i>
        <input type="text" id="searchProduit" placeholder="Rechercher un produit…"
               class="produits-search-input" oninput="filterProduits()">
      </div>
      <div class="produits-cats" id="catButtons">
        <button class="cat-btn active" data-cat="tous" onclick="setCat(this,'tous')">Tous</button>
        <button class="cat-btn" data-cat="vernis" onclick="setCat(this,'vernis')"><i class="bi bi-droplet me-1"></i>Vernis</button>
        <button class="cat-btn" data-cat="soins"  onclick="setCat(this,'soins')"><i class="bi bi-heart me-1"></i>Soins</button>
        <button class="cat-btn" data-cat="outils" onclick="setCat(this,'outils')"><i class="bi bi-tools me-1"></i>Outils</button>
        <button class="cat-btn" data-cat="deco"   onclick="setCat(this,'deco')"><i class="bi bi-stars me-1"></i>Déco</button>
        <button class="cat-btn" data-cat="beaute" onclick="setCat(this,'beaute')"><i class="bi bi-gem me-1"></i>Beauté</button>
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <span id="resultCount" class="result-count"></span>
      <span style="font-size:11px;color:#bbb;letter-spacing:2px;text-transform:uppercase;">Super Beauty Market</span>
    </div>

    <!-- Grille produits -->
    <div class="row g-4" id="produitsGrid">
      <% if (produits && produits.length > 0) { %>
        <% produits.forEach(function(p, idx) {
             const hasRemise  = p.remise_type && p.remise_type !== 'none' && p.remise_valeur > 0;
             const prixFinal  = hasRemise
               ? (p.remise_type === 'pourcentage' ? p.prix * (1 - p.remise_valeur/100) : p.prix - p.remise_valeur)
               : p.prix;
        %>
        <div class="col-6 col-md-4 col-lg-3 produit-item reveal-fade"
             style="transition-delay:<%= idx * 0.05 %>s"
             data-nom="<%= p.nom.toLowerCase() %>"
             data-desc="<%= (p.description||'').toLowerCase() %>"
             data-cat="<%= (p.categorie||'beaute').toLowerCase() %>">

          <div class="product-card h-100">

            <!-- Badges positionnés -->
            <% if (hasRemise) { %>
            <div class="pcard-badge sale">
              -<%= p.remise_type === 'pourcentage' ? Math.round(p.remise_valeur)+'%' : Number(p.remise_valeur).toLocaleString('fr-FR')+'F' %>
            </div>
            <% } %>
            <% if (p.stock <= 0) { %>
            <div class="pcard-badge rupture">Rupture</div>
            <% } else if (p.stock > 0 && p.stock <= 5) { %>
            <div class="pcard-badge warning">Dernières pièces</div>
            <% } %>

            <div class="product-img-wrap">
              <img src="/images/<%= p.image || 'nail-01.jpg' %>" alt="<%= p.nom %>"
                   class="product-img" onerror="this.onerror=null;this.src='/images/nail-01.jpg'">

              <!-- Overlay bouton ajouter -->
              <% if (p.stock > 0) { %>
              <div class="pcard-hover">
                <button class="pcard-add-btn"
                  onclick='addToCart(<%= JSON.stringify({id:p.id, nom:p.nom, prix:prixFinal, image:p.image||"nail-01.jpg"}) %>)'>
                  <i class="bi bi-cart-plus me-2"></i>Ajouter au panier
                </button>
              </div>
              <% } else { %>
              <div class="pcard-hover" style="cursor:default;">
                <span style="color:#fff;font-size:12px;font-weight:700;letter-spacing:1px;">RUPTURE DE STOCK</span>
              </div>
              <% } %>
            </div>

            <div class="product-body p-3">
              <div style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#a07cc0;font-weight:700;margin-bottom:4px;">
                <%= p.categorie || 'Beauté' %>
              </div>
              <h6 style="font-family:'Playfair Display',serif;font-size:0.92rem;font-weight:400;
                          color:#2d1f45;line-height:1.35;margin:0 0 6px;">
                <%= p.nom %>
              </h6>
              <p style="font-size:11px;color:#999;line-height:1.55;margin-bottom:10px;min-height:32px;">
                <%= p.description ? p.description.substring(0,60)+(p.description.length>60?'…':'') : '' %>
              </p>

              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <% if (hasRemise) { %>
                  <div style="font-size:11px;color:#ccc;text-decoration:line-through;line-height:1;">
                    <%= Number(p.prix).toLocaleString('fr-FR') %> F
                  </div>
                  <div style="font-family:'Playfair Display',serif;font-size:1.05rem;color:#c94d9a;font-weight:700;">
                    <%= Number(prixFinal).toLocaleString('fr-FR') %> <small style="font-size:9px;color:#bbb;font-family:'Jost',sans-serif;">FCFA</small>
                  </div>
                  <% } else { %>
                  <div style="font-family:'Playfair Display',serif;font-size:1.05rem;color:#a07cc0;">
                    <%= Number(prixFinal).toLocaleString('fr-FR') %> <small style="font-size:9px;color:#bbb;font-family:'Jost',sans-serif;">FCFA</small>
                  </div>
                  <% } %>
                </div>

                <% if (p.stock > 0) { %>
                <button class="pcard-quick-add"
                  onclick='addToCart(<%= JSON.stringify({id:p.id, nom:p.nom, prix:prixFinal, image:p.image||"nail-01.jpg"}) %>)'
                  title="Ajouter au panier">
                  <i class="bi bi-cart-plus"></i>
                </button>
                <% } else { %>
                <span style="font-size:10px;color:#e74c3c;"><i class="bi bi-x-circle"></i></span>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      <% } %>
    </div>

    <div id="noResults" style="display:none;text-align:center;padding:60px 0;">
      <div style="font-size:3rem;margin-bottom:12px;">🔍</div>
      <p class="text-muted">Aucun produit trouvé pour cette recherche.</p>
      <button onclick="resetFilters()" class="btn btn-sm btn-outline-dark" style="border-radius:0;font-size:11px;letter-spacing:1px;">Voir tous les produits</button>
    </div>

    <% if (!produits || produits.length === 0) { %>
    <div class="col-12 text-center py-5">
      <i class="bi bi-bag fs-1 text-muted"></i>
      <p class="text-muted mt-3">Produits bientôt disponibles.</p>
    </div>
    <% } %>
  </div>
</section>

<!-- ══════════════════════════════════════════
     MODAL PANIER + CHECKOUT
══════════════════════════════════════════ -->
<div id="shopModal" onclick="if(event.target===this)closeModal()"
  style="display:none;position:fixed;inset:0;background:rgba(10,4,22,0.55);
  z-index:2000;overflow-y:auto;padding:20px 16px;">
  <div style="max-width:560px;margin:0 auto;background:#fff;border-radius:14px;
    overflow:hidden;box-shadow:0 8px 40px rgba(45,31,69,0.18);" id="shopModalBox">

    <!-- ── ÉTAPE 1 : PANIER ── -->
    <div id="step1">
      <div style="background:#faf8fc;border-bottom:1px solid #ede5f7;padding:18px 24px;
        display:flex;justify-content:space-between;align-items:center;">
        <div style="display:flex;align-items:center;gap:10px;">
          <i class="bi bi-bag" style="font-size:1.3rem;color:#8860a8;"></i>
          <h5 style="font-size:1rem;font-weight:700;color:#2d1f45;margin:0;">Mon Panier</h5>
        </div>
        <button onclick="closeModal()" style="background:none;border:none;color:#aaa;
          width:32px;height:32px;font-size:18px;cursor:pointer;border-radius:50%;
          display:flex;align-items:center;justify-content:center;transition:background 0.2s;"
          onmouseover="this.style.background='#f0e8f8'" onmouseout="this.style.background='none'">×</button>
      </div>

      <div id="cartItemsEl" style="padding:16px 24px;max-height:320px;overflow-y:auto;"></div>

      <div style="padding:14px 24px;border-top:1px solid #f0eaf8;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
          <span style="font-size:13px;color:#777;">Total</span>
          <span id="modalTotal" style="font-size:1.2rem;color:#2d1f45;font-weight:700;"></span>
        </div>
        <button onclick="goStep(2)" style="width:100%;background:#2d1f45;
          color:#fff;border:none;border-radius:8px;padding:13px;font-size:12px;
          font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;transition:background 0.2s;"
          onmouseover="this.style.background='#8860a8'"
          onmouseout="this.style.background='#2d1f45'">
          Passer commande →
        </button>
        <button onclick="closeModal()" style="width:100%;background:none;border:none;
          color:#bbb;font-size:12px;margin-top:8px;cursor:pointer;letter-spacing:1px;">
          Continuer mes achats
        </button>
      </div>
    </div>

    <!-- ── ÉTAPE 2 : CHECKOUT ── -->
    <div id="step2" style="display:none;">
      <div style="background:#faf8fc;border-bottom:1px solid #ede5f7;padding:18px 24px;
        display:flex;justify-content:space-between;align-items:center;">
        <div style="display:flex;align-items:center;gap:10px;">
          <span style="font-size:10px;color:#aaa;letter-spacing:1px;text-transform:uppercase;">Étape 2 / 3</span>
          <h5 style="font-size:1rem;font-weight:700;color:#2d1f45;margin:2px 0 0;">
            Vos informations
          </h5>
        </div>
        <button onclick="closeModal()" style="background:none;border:none;color:#aaa;
          width:32px;height:32px;font-size:18px;cursor:pointer;border-radius:50%;
          display:flex;align-items:center;justify-content:center;transition:background 0.2s;"
          onmouseover="this.style.background='#f0e8f8'" onmouseout="this.style.background='none'">×</button>
      </div>

      <div style="padding:24px 28px;max-height:80vh;overflow-y:auto;">

        <!-- Champs infos -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
          <div>
            <label class="flabel">Prénom *</label>
            <input id="f_prenom" type="text" class="finput" placeholder="Aminata">
          </div>
          <div>
            <label class="flabel">Nom *</label>
            <input id="f_nom" type="text" class="finput" placeholder="Diallo">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
          <div>
            <label class="flabel">Téléphone Sénégal *</label>
            <div style="display:flex;border:1.5px solid #e0d0ee;border-radius:8px;overflow:hidden;background:#f9f3fd;">
              <span style="padding:10px 10px;color:#a07cc0;font-size:12px;font-weight:700;
                border-right:1px solid #e0d0ee;white-space:nowrap;background:rgba(160,124,192,0.06);">+221</span>
              <input id="f_telephone" type="tel" style="flex:1;border:none;background:transparent;
                padding:10px 12px;font-size:13px;outline:none;" placeholder="7X XXX XX XX">
            </div>
          </div>
          <div>
            <label class="flabel">Email</label>
            <input id="f_email" type="email" class="finput" placeholder="votre@email.com">
          </div>
        </div>
        <div style="margin-bottom:20px;">
          <label class="flabel">Adresse de livraison (optionnel)</label>
          <input id="f_adresse" type="text" class="finput" placeholder="Quartier, Commune, Dakar…">
        </div>

        <!-- Modes de paiement -->
        <div style="margin-bottom:20px;">
          <label class="flabel" style="display:block;margin-bottom:12px;">Mode de paiement *</label>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">

            <label class="payopt" id="opt-especes">
              <input type="radio" name="pay" value="especes" style="display:none" onchange="onPayChange('especes')">
              <span style="font-size:1.6rem;">💵</span>
              <div>
                <div style="font-size:12px;font-weight:700;color:#2d1f45;">Espèces</div>
                <div style="font-size:10px;color:#aaa;">À la livraison / en salon</div>
              </div>
            </label>

            <label class="payopt" id="opt-wave">
              <input type="radio" name="pay" value="wave" style="display:none" onchange="onPayChange('wave')">
              <img src="/images/wave-logo.webp" alt="Wave" style="height:26px;object-fit:contain;flex-shrink:0;">
              <div>
                <div style="font-size:12px;font-weight:700;color:#2d1f45;">Wave</div>
                <div style="font-size:10px;color:#aaa;">Paiement mobile</div>
              </div>
            </label>

            <label class="payopt" id="opt-orange_money">
              <input type="radio" name="pay" value="orange_money" style="display:none" onchange="onPayChange('orange_money')">
              <img src="/images/orange-money-logo.webp" alt="Orange Money" style="height:26px;object-fit:contain;flex-shrink:0;">
              <div>
                <div style="font-size:12px;font-weight:700;color:#2d1f45;">Orange Money</div>
                <div style="font-size:10px;color:#aaa;">Paiement mobile</div>
              </div>
            </label>

            <label class="payopt" id="opt-virement">
              <input type="radio" name="pay" value="virement" style="display:none" onchange="onPayChange('virement')">
              <span style="font-size:1.6rem;">🏦</span>
              <div>
                <div style="font-size:12px;font-weight:700;color:#2d1f45;">Virement</div>
                <div style="font-size:10px;color:#aaa;">Virement bancaire</div>
              </div>
            </label>

          </div>
        </div>

        <!-- Info Wave -->
        <div id="info-wave" style="display:none;background:linear-gradient(135deg,#e8f8ff,#d0f0fb);
          border-radius:10px;padding:14px;margin-bottom:14px;border-left:3px solid #00b4f1;">
          <div style="font-size:10px;font-weight:700;color:#0090c2;letter-spacing:2px;margin-bottom:6px;">NUMÉRO WAVE SUPER BEAUTY MARKET</div>
          <div style="font-size:1.1rem;font-weight:700;color:#006d9b;">+221 78 247 81 47</div>
          <div style="font-size:11px;color:#555;margin-top:6px;">Envoyez le montant exact puis entrez la référence Wave ci-dessous.</div>
          <input id="f_ref_wave" type="text" class="finput" style="margin-top:10px;" placeholder="Référence Wave (ex: WV7654321)">
        </div>

        <!-- Info Orange Money -->
        <div id="info-orange_money" style="display:none;background:linear-gradient(135deg,#fff5e8,#fde8c8);
          border-radius:10px;padding:14px;margin-bottom:14px;border-left:3px solid #f60;">
          <div style="font-size:10px;font-weight:700;color:#f60;letter-spacing:2px;margin-bottom:6px;">NUMÉRO ORANGE MONEY SUPER BEAUTY MARKET</div>
          <div style="font-size:1.1rem;font-weight:700;color:#c25000;">+221 78 136 53 58</div>
          <div style="font-size:11px;color:#555;margin-top:6px;">Envoyez le montant exact puis entrez la référence Orange Money ci-dessous.</div>
          <input id="f_ref_om" type="text" class="finput" style="margin-top:10px;" placeholder="Référence Orange Money (ex: OM1234567)">
        </div>

        <!-- Info Virement -->
        <div id="info-virement" style="display:none;background:#f8f9fa;border-radius:10px;
          padding:14px;margin-bottom:14px;border-left:3px solid #aaa;">
          <div style="font-size:10px;font-weight:700;color:#666;letter-spacing:2px;margin-bottom:8px;">COORDONNÉES BANCAIRES</div>
          <div style="font-family:monospace;font-size:12px;color:#333;line-height:2;">
            Banque : <strong>BICIS / Ecobank Sénégal</strong><br>
            Bénéficiaire : <strong>Super Beauty Market</strong><br>
            Motif : <strong>Commande produits</strong>
          </div>
          <div style="font-size:11px;color:#999;margin-top:8px;">Votre commande sera traitée dès réception du virement.</div>
        </div>

        <!-- Note -->
        <div style="margin-bottom:20px;">
          <label class="flabel">Note / précisions (optionnel)</label>
          <textarea id="f_notes" class="finput" rows="2" style="resize:none;"
            placeholder="Ex: livraison en soirée, couleur souhaitée…"></textarea>
        </div>

        <!-- Récap commande -->
        <div style="background:#fdf9ff;border-radius:10px;padding:14px;border:1px solid #f0e6f6;margin-bottom:16px;">
          <div style="font-size:10px;font-weight:700;letter-spacing:2px;color:#a07cc0;margin-bottom:10px;">RÉCAPITULATIF</div>
          <div id="checkoutSummary" style="font-size:12px;color:#666;line-height:2.2;"></div>
          <div style="display:flex;justify-content:space-between;align-items:center;
            border-top:1px solid #f0e6f6;padding-top:10px;margin-top:8px;">
            <span style="font-size:13px;font-weight:600;color:#333;">Total à payer</span>
            <span id="checkoutTotalEl" style="font-family:'Playfair Display',serif;
              font-size:1.25rem;color:#c94d9a;font-weight:700;"></span>
          </div>
        </div>

        <button id="submitBtn" onclick="submitOrder()"
          style="width:100%;background:#2d1f45;
          color:#fff;border:none;border-radius:8px;padding:13px;font-size:12px;
          font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;transition:background 0.2s;"
          onmouseover="this.style.background='#8860a8'"
          onmouseout="this.style.background='#2d1f45'">
          ✓ Confirmer la commande
        </button>
        <button onclick="goStep(1)" style="width:100%;background:none;border:none;
          color:#bbb;font-size:12px;margin-top:10px;cursor:pointer;letter-spacing:1px;">
          ← Retour au panier
        </button>
      </div>
    </div>

    <!-- ── ÉTAPE 3 : CONFIRMATION ── -->
    <div id="step3" style="display:none;text-align:center;padding:52px 28px;">
      <div style="font-size:4.5rem;margin-bottom:16px;animation:bounceIn 0.5s cubic-bezier(0.16,1,0.3,1);">✅</div>
      <h4 style="font-family:'Playfair Display',serif;font-style:italic;
        color:#2d1f45;font-size:1.7rem;margin-bottom:8px;">Commande confirmée !</h4>
      <p style="color:#aaa;font-size:12px;margin-bottom:4px;">Numéro de commande</p>
      <div id="confNumero" style="font-family:monospace;font-size:1.2rem;font-weight:700;
        color:#a07cc0;background:#f3e5f5;padding:8px 20px;border-radius:8px;
        display:inline-block;margin-bottom:20px;letter-spacing:3px;"></div>
      <p id="confMessage" style="color:#555;font-size:13px;line-height:1.75;
        max-width:420px;margin:0 auto 24px;"></p>
      <div style="background:#fdf0fb;border-radius:12px;padding:16px 20px;margin-bottom:24px;display:inline-block;">
        <div style="font-size:10px;font-weight:700;color:#a07cc0;letter-spacing:2px;margin-bottom:10px;">NOUS CONTACTER</div>
        <a href="tel:+221782478147" style="display:block;color:#2d1f45;font-weight:700;font-size:14px;text-decoration:none;">
          📞 +221 78 247 81 47
        </a>
        <a href="https://wa.me/221782478147" target="_blank"
          style="display:inline-flex;align-items:center;gap:6px;margin-top:10px;
