<!-- ══════════════════════════════════════════
     STYLES PRODUITS PAGE
══════════════════════════════════════════ -->
<style>
.pay-chip { display:inline-flex;align-items:center;gap:6px;background:#fff;border:1.5px solid #e0d0ee;
  border-radius:20px;padding:6px 14px;font-size:11px;font-weight:600;color:#555;letter-spacing:0.5px;
  box-shadow:0 2px 10px rgba(160,124,192,0.08); }
.wave-chip { border-color:#00b4f1;color:#0090c2; }
.om-chip { border-color:#f60;color:#cc4400; }

.pcard-badge { position:absolute;z-index:3;font-size:9px;font-weight:800;
  letter-spacing:1px;padding:4px 9px;border-radius:4px;text-transform:uppercase; }
.pcard-badge.sale { top:10px;right:10px;background:linear-gradient(135deg,#c94d9a,#a07cc0);color:#fff; }
.pcard-badge.rupture { top:10px;left:10px;background:rgba(231,76,60,0.92);color:#fff; }
.pcard-badge.warning { top:10px;left:10px;background:rgba(230,126,34,0.92);color:#fff; }

.pcard-hover { position:absolute;inset:0;background:rgba(45,31,69,0.72);display:flex;
  align-items:center;justify-content:center;opacity:0;transition:opacity 0.3s;backdrop-filter:blur(3px); }
.product-img-wrap:hover .pcard-hover { opacity:1; }
.pcard-add-btn { background:linear-gradient(135deg,#c94d9a,#a07cc0);color:#fff;border:none;
  border-radius:8px;padding:11px 22px;font-size:11px;font-weight:800;letter-spacing:1.5px;
  text-transform:uppercase;cursor:pointer;transition:transform 0.15s; }
.pcard-add-btn:hover { transform:scale(1.06); }

.pcard-quick-add { width:36px;height:36px;border-radius:8px;border:none;flex-shrink:0;
  background:linear-gradient(135deg,#2d1f45,#8860a8);color:#fff;font-size:16px;
  display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all 0.2s; }
.pcard-quick-add:hover { transform:scale(1.12);box-shadow:0 4px 12px rgba(45,31,69,0.3); }

.flabel { display:block;font-size:10px;letter-spacing:2px;text-transform:uppercase;
  color:#999;font-weight:700;margin-bottom:6px; }
.finput { width:100%;padding:10px 14px;border:1.5px solid #e0d0ee;border-radius:8px;
  font-size:13px;color:#333;background:#f9f3fd;outline:none;transition:all 0.2s;box-sizing:border-box; }
.finput:focus { border-color:#a07cc0;background:#fff;box-shadow:0 0 0 3px rgba(160,124,192,0.12); }

.payopt { display:flex;align-items:center;gap:12px;padding:14px;border:2px solid #e0d0ee;
  border-radius:10px;cursor:pointer;transition:all 0.2s;background:#fff;user-select:none; }
.payopt:hover { border-color:#a07cc0;background:#fdf9ff; }
.payopt.selected { border-color:#c94d9a;background:linear-gradient(135deg,#fdf0fb,#f3e5f5); }

.cart-row { display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid #f0e6f6; }
.cart-row:last-child { border:none; }

@keyframes bounceIn { 0%{transform:scale(0)} 70%{transform:scale(1.18)} 100%{transform:scale(1)} }
</style>

<!-- ══════════════════════════════════════════
     LOGIQUE PANIER + COMMANDE
══════════════════════════════════════════ -->
<script>
/* ── État panier ── */
let cart = JSON.parse(sessionStorage.getItem('kb_cart') || '[]');
let payMode = '';

const saveCart = () => sessionStorage.setItem('kb_cart', JSON.stringify(cart));

function addToCart(prod) {
  const ex = cart.find(i => i.id === prod.id);
  if (ex) ex.quantite++;
  else cart.push({ ...prod, quantite: 1 });
  saveCart();
  updateBarUI();
  showAddedToast(prod.nom);
}

function removeItem(id) {
  cart = cart.filter(i => i.id !== id);
  saveCart(); updateBarUI(); renderCartRows();
}
function changeQty(id, d) {
  const it = cart.find(i => i.id === id);
  if (it) { it.quantite = Math.max(1, it.quantite + d); saveCart(); updateBarUI(); renderCartRows(); }
}

const totalVal  = () => cart.reduce((s, i) => s + i.prix * i.quantite, 0);
const totalCount = () => cart.reduce((s, i) => s + i.quantite, 0);

function updateBarUI() {
  const n = totalCount();
  document.getElementById('cartCountBadge').textContent = n;
  document.getElementById('cartTotalBar').textContent = Number(totalVal()).toLocaleString('fr-FR');
  document.getElementById('cartBar').style.display = n > 0 ? 'block' : 'none';
}

function renderCartRows() {
  const el = document.getElementById('cartItemsEl');
  if (!cart.length) {
    el.innerHTML = '<div style="text-align:center;padding:40px 0;color:#ccc;"><div style="font-size:2.5rem;margin-bottom:8px;">🛒</div>Votre panier est vide</div>';
    document.getElementById('modalTotal').textContent = '0 FCFA';
    return;
  }
  el.innerHTML = cart.map(it => `
    <div class="cart-row">
      <img src="/images/${it.image}" style="width:52px;height:52px;object-fit:cover;border-radius:8px;flex-shrink:0;" onerror="this.src='/images/nail-01.jpg'">
      <div style="flex:1;min-width:0;">
        <div style="font-size:13px;font-weight:600;color:#2d1f45;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${it.nom}</div>
        <div style="font-size:12px;color:#a07cc0;font-weight:600;">${Number(it.prix).toLocaleString('fr-FR')} FCFA</div>
      </div>
      <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
        <button onclick="changeQty(${it.id},-1)" style="width:26px;height:26px;border-radius:50%;border:1px solid #e0d0ee;background:#fff;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;color:#555;">−</button>
        <span style="font-size:13px;font-weight:700;min-width:20px;text-align:center;">${it.quantite}</span>
        <button onclick="changeQty(${it.id},1)"  style="width:26px;height:26px;border-radius:50%;border:1px solid #e0d0ee;background:#fff;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;color:#555;">+</button>
        <button onclick="removeItem(${it.id})"   style="width:26px;height:26px;border-radius:50%;border:none;background:#fdf0f0;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;color:#e74c3c;margin-left:2px;">🗑</button>
      </div>
    </div>`).join('');
  document.getElementById('modalTotal').textContent = Number(totalVal()).toLocaleString('fr-FR') + ' FCFA';
}

function openModal() {
  renderCartRows();
  goStep(1);
  document.getElementById('shopModal').style.display = 'block';
  document.body.style.overflow = 'hidden';
}
function closeModal() {
  document.getElementById('shopModal').style.display = 'none';
  document.body.style.overflow = '';
}

function goStep(n) {
  [1,2,3].forEach(i => document.getElementById('step'+i).style.display = 'none');
  document.getElementById('step'+n).style.display = '';
  if (n === 2) {
    // Préremplir récap
    document.getElementById('checkoutSummary').innerHTML =
      cart.map(i => `<div style="display:flex;justify-content:space-between;"><span>${i.nom} ×${i.quantite}</span><span style="font-weight:600;">${Number(i.prix*i.quantite).toLocaleString('fr-FR')} F</span></div>`).join('');
    document.getElementById('checkoutTotalEl').textContent = Number(totalVal()).toLocaleString('fr-FR') + ' FCFA';
    payMode = '';
    document.querySelectorAll('.payopt').forEach(o => o.classList.remove('selected'));
    ['wave','orange_money','virement'].forEach(k => { const el = document.getElementById('info-'+k); if(el) el.style.display='none'; });
  }
  // Scroll to top of modal
  document.getElementById('shopModalBox').scrollIntoView({ behavior:'smooth', block:'start' });
}

function onPayChange(mode) {
  payMode = mode;
  document.querySelectorAll('.payopt').forEach(o => o.classList.remove('selected'));
  const sel = document.getElementById('opt-'+mode);
  if (sel) sel.classList.add('selected');
  ['wave','orange_money','virement'].forEach(k => {
    const el = document.getElementById('info-'+k);
    if (el) el.style.display = (k === mode) ? '' : 'none';
  });
}

async function submitOrder() {
  const prenom = document.getElementById('f_prenom').value.trim();
  const nom    = document.getElementById('f_nom').value.trim();
  const tel    = document.getElementById('f_telephone').value.trim();

  if (!prenom || !nom || !tel) { alert('Veuillez remplir les champs : prénom, nom et téléphone.'); return; }
  if (!payMode)                { alert('Veuillez choisir un mode de paiement.'); return; }
  if (!cart.length)            { alert('Votre panier est vide.'); return; }

  const btn = document.getElementById('submitBtn');
  btn.disabled = true; btn.textContent = 'Envoi…';

  let ref = '';
  if (payMode === 'wave')         ref = document.getElementById('f_ref_wave')?.value?.trim() || '';
  if (payMode === 'orange_money') ref = document.getElementById('f_ref_om')?.value?.trim()   || '';

  try {
    const resp = await fetch('/commandes', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        prenom, nom,
        telephone: '+221 ' + tel.replace(/\D/g,''),
        email:    document.getElementById('f_email').value.trim()   || '',
        adresse:  document.getElementById('f_adresse').value.trim() || '',
        mode_paiement: payMode,
        ref_paiement:  ref,
        notes: document.getElementById('f_notes').value.trim() || '',
        items: JSON.stringify(cart)
      })
    });
    const data = await resp.json();

    if (data.success) {
      const labels = { especes:'en espèces (à la livraison ou en salon)', wave:'par Wave 📲', orange_money:'par Orange Money 📱', virement:'par virement bancaire 🏦' };
      document.getElementById('confNumero').textContent  = data.numero;
      document.getElementById('confMessage').innerHTML   =
        `Merci <strong>${prenom}</strong> ! Votre commande de <strong>${Number(data.total).toLocaleString('fr-FR')} FCFA</strong> a bien été reçue.<br>
         Paiement : <strong>${labels[payMode]}</strong>.<br><br>
         Notre équipe vous contactera rapidement pour confirmer et organiser la livraison. 💜`;
      goStep(3);
    } else {
      alert('Erreur : ' + (data.error || 'Réessayez'));
      btn.disabled = false; btn.textContent = '✓ Confirmer la commande';
    }
  } catch(e) {
    alert('Erreur réseau. Vérifiez votre connexion et réessayez.');
    btn.disabled = false; btn.textContent = '✓ Confirmer la commande';
  }
}

function resetCart() {
  cart = []; saveCart(); updateBarUI();
}

function showAddedToast(nom) {
  let t = document.querySelector('.kb-toast');
  if (!t) {
    t = document.createElement('div');
    t.className = 'kb-toast';
    t.style.cssText = `position:fixed;top:80px;right:20px;z-index:9999;
      background:linear-gradient(135deg,#2d1f45,#8860a8);color:#fff;
      padding:12px 20px;border-radius:10px;font-size:13px;max-width:280px;
      box-shadow:0 8px 30px rgba(45,31,69,0.3);transform:translateX(130%);
      transition:transform 0.4s cubic-bezier(0.16,1,0.3,1);`;
    document.body.appendChild(t);
  }
  t.innerHTML = `<i class="bi bi-cart-check me-2"></i><strong>${nom.substring(0,28)}</strong> ajouté !`;
  t.style.transform = 'translateX(0)';
  clearTimeout(t._timer);
  t._timer = setTimeout(() => { t.style.transform = 'translateX(130%)'; }, 2600);
}

/* ── Filtres catalogue ── */
let currentCat = 'tous';
function filterProduits() {
  const s = document.getElementById('searchProduit').value.toLowerCase().trim();
  let n = 0;
  document.querySelectorAll('.produit-item').forEach(el => {
    const ok = (!s || el.dataset.nom.includes(s) || el.dataset.desc.includes(s))
            && (currentCat === 'tous' || el.dataset.cat === currentCat);
    el.style.display = ok ? '' : 'none';
    if (ok) n++;
  });
  document.getElementById('resultCount').textContent = n + ' produit' + (n > 1 ? 's' : '') + ' trouvé' + (n > 1 ? 's' : '');
  document.getElementById('noResults').style.display = n === 0 ? 'block' : 'none';
}
function setCat(btn, cat) {
  currentCat = cat;
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('searchProduit').value = '';
  filterProduits();
}
function resetFilters() {
  currentCat = 'tous';
  document.getElementById('searchProduit').value = '';
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
  document.querySelector('[data-cat="tous"]').classList.add('active');
  filterProduits();
}

document.addEventListener('DOMContentLoaded', () => { updateBarUI(); filterProduits(); });
</script>

