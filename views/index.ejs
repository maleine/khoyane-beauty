<%- include('partials/header') %>

<!-- KHOYANE BEAUTY BRAND STRIP -->
<div class="khoyane-brand-strip">
  <div class="khoyane-strip-content">
    <span class="khoyane-strip-divider">✦</span>
    <span class="khoyane-strip-logo">Khoyane</span>
    <span class="khoyane-strip-sub">Beauty</span>
    <span class="khoyane-strip-divider">✦</span>
    <span class="khoyane-strip-tagline">L'art de sublimer vos ongles · Dakar, Yoff Apecsy</span>
    <span class="khoyane-strip-divider">✦</span>
  </div>
</div>

<!-- HERO SECTION -->
<section class="hero-section">
  <div class="hero-overlay"></div>
  <div class="hero-particles"></div>
  <div class="hero-watermark">Khoyane Beauty</div>
  <img src="/images/hero-main.jpg" alt="Nail Art Hero" class="hero-bg" onerror="this.onerror=null; this.src='/images/nail-01.jpg'">
  <div class="hero-social">
    <a href="#" class="hero-social-link">Tiktok</a>
    <a href="#" class="hero-social-link">Twitter</a>
    <a href="#" class="hero-social-link">Instagram</a>
    <a href="#" class="hero-social-link">Facebook</a>
  </div>
  <div class="hero-content">
    <p class="hero-subtitle" style="font-size:3.5rem; color:var(--gold); text-shadow:0 0 30px rgba(160,124,192,0.5);">Khoyane Beauty</p>
    <h1 class="hero-title">ART MANICURE</h1>
    <p class="hero-desc">Styles de couleurs créatifs. Toujours tendance. Meilleure qualité.</p>
    <a href="/services" class="btn btn-hero mt-3">Découvrir →</a>
  </div>
  <div class="hero-dots">
    <span class="hero-dot active"></span>
    <span class="hero-dot"></span>
    <span class="hero-dot"></span>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator">
    <div class="scroll-indicator-mouse">
      <div class="scroll-indicator-wheel"></div>
    </div>
    <div class="scroll-indicator-text">Défiler</div>
  </div>
</section>

<!-- ABOUT SECTION -->
<section class="about-section py-5">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-5">
        <p class="section-pre">Notre Studio</p>
        <div class="khoyane-about-badge animate-on-scroll from-left">
          <i class="bi bi-gem"></i> Khoyane Beauty · Dakar
        </div>
        <h2 class="section-title">Studio créatif de <em>manucure et pédicure</em> pour la beauté de vos ongles — Yoff Apecsy, Dakar</h2>
        <p class="section-text">Nous offrons des services de beauté haut de gamme avec des techniques modernes et des produits naturels premium. Chaque cliente repart avec des ongles sublimes.</p>
        <div class="row stats-row mt-4">
          <div class="col-4 text-center">
            <div class="stat-number">13+</div>
            <div class="stat-label">Années d'expérience</div>
          </div>
          <div class="col-4 text-center">
            <div class="stat-number">25</div>
            <div class="stat-label">Experts beauté</div>
          </div>
          <div class="col-4 text-center">
            <div class="stat-number">5k+</div>
            <div class="stat-label">Clientes satisfaites</div>
          </div>
        </div>
      </div>
      <div class="col-md-7">
        <div class="about-images row g-3 mt-4 mt-md-0">
          <div class="col-6">
            <img src="/images/nail-01.jpg" alt="Nail Art" class="img-fluid rounded about-img-1" onerror="this.onerror=null; this.src='/images/nail-01.jpg'">
          </div>
          <div class="col-6 mt-4">
            <img src="/images/nail-05.jpg" alt="Nail Art" class="img-fluid rounded about-img-2" onerror="this.onerror=null; this.src='/images/nail-01.jpg'">
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES ICONS -->
<section class="services-icons-section py-5">
  <div class="container">
    <div class="row text-center g-4 animate-stagger">
      <div class="col-6 col-md-3">
        <div class="service-icon-card">
          <div class="service-icon-circle">
            <i class="bi bi-hand-index"></i>
          </div>
          <h5 class="service-icon-title">MANUCURE</h5>
          <p class="service-icon-desc">Soin complet des ongles avec des techniques professionnelles</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="service-icon-card">
          <div class="service-icon-circle">
            <i class="bi bi-person-standing"></i>
          </div>
          <h5 class="service-icon-title">PÉDICURE</h5>
          <p class="service-icon-desc">Traitement complet pieds et ongles pour votre confort</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="service-icon-card">
          <div class="service-icon-circle">
            <i class="bi bi-stars"></i>
          </div>
          <h5 class="service-icon-title">SOIN ONGLES</h5>
          <p class="service-icon-desc">Soins nourrissants et protecteurs pour des ongles sains</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="service-icon-card">
          <div class="service-icon-circle">
            <i class="bi bi-flower1"></i>
          </div>
          <h5 class="service-icon-title">COSMÉTIQUES</h5>
          <p class="service-icon-desc">Produits naturels premium pour des résultats durables</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PREMIUM COSMETICS SECTION -->
<section class="cosmetics-section animate-on-scroll from-left">
  <div class="container-fluid px-0">
    <div class="row g-0 align-items-center">
      <div class="col-md-6">
        <div class="cosmetics-image-wrap">
          <img src="/images/nail-10.jpg" alt="Premium Cosmetics" class="w-100 cosmetics-img" onerror="this.onerror=null; this.src='/images/nail-01.jpg'">
          <div class="cosmetics-badge">
            <span>HIGH QUALITY</span>
            <span>NATURAL NAILS</span>
          </div>
        </div>
      </div>
      <div class="col-md-6 cosmetics-text-wrap">
        <p class="section-pre gold">matériaux</p>
        <h2 class="section-title">ONLY NATURAL<br>PREMIUM COSMETICS</h2>
        <p class="section-text">Nous utilisons exclusivement des produits naturels et certifiés pour prendre soin de vos ongles. Notre gamme premium garantit des résultats durables sans compromettre votre santé.</p>
        <a href="/produits" class="btn btn-outline-dark mt-3">Voir les produits →</a>
      </div>
    </div>
  </div>
</section>

<!-- TARIFS KHOYANE BEAUTY -->
<section class="offers-section py-5">
  <div class="container">
    <p class="section-pre text-center gold">tarifs mains</p>
    <h2 class="section-title text-center mb-2">NOS PRESTATIONS</h2>
    <div class="section-divider-kb"><span>❧</span></div>
    <p class="text-center text-muted mb-5 small">Design à partir de 1.000fr — X-tra longueur +2.000fr</p>

    <div class="row g-5">
      <!-- POSE MAINS -->
      <div class="col-md-6">
        <h5 class="tarif-cat-title mb-4">POSE</h5>
        <div class="tarif-list">
          <div class="tarif-row"><span class="tarif-name">Vernis perm/ongles naturel</span><span class="tarif-dots"></span><span class="tarif-price">5.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Pose américaine</span><span class="tarif-dots"></span><span class="tarif-price">7.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Pose américaine XL</span><span class="tarif-dots"></span><span class="tarif-price">10.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Gainage</span><span class="tarif-dots"></span><span class="tarif-price">10.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Gel-X</span><span class="tarif-dots"></span><span class="tarif-price">10.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Gel / Résine extension</span><span class="tarif-dots"></span><span class="tarif-price">12.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Pop It (sans colle)</span><span class="tarif-dots"></span><span class="tarif-price">15.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Chabblon (sans colle)</span><span class="tarif-dots"></span><span class="tarif-price">18.000fr</span></div>
        </div>
        <div class="tarif-note mt-3">
          <i class="bi bi-info-circle me-1"></i> Design non compris dans ces tarifs
        </div>
      </div>
      <!-- SOINS MAINS -->
      <div class="col-md-6">
        <h5 class="tarif-cat-title mb-4">SOINS MAINS</h5>
        <div class="tarif-note mb-3"><i class="bi bi-info-circle me-1"></i> Pose non comprise</div>
        <div class="tarif-list">
          <div class="tarif-row"><span class="tarif-name">Manucure simple</span><span class="tarif-dots"></span><span class="tarif-price">5.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Manucure jelly-spa</span><span class="tarif-dots"></span><span class="tarif-price">10.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Manucure parafin</span><span class="tarif-dots"></span><span class="tarif-price">15.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Dépose cap-american</span><span class="tarif-dots"></span><span class="tarif-price">4.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Dépose gel main</span><span class="tarif-dots"></span><span class="tarif-price">5.000fr</span></div>
          <div class="tarif-row"><span class="tarif-name">Dépose résine main</span><span class="tarif-dots"></span><span class="tarif-price">6.000fr</span></div>
        </div>
        <div class="tarif-nb mt-4 p-3">
          <strong>NB :</strong> Design à partir de 1.000fr.<br>
          <strong>X-tra longueur plus 2.000fr.</strong>
        </div>
      </div>
    </div>
    <div class="text-center mt-5">
      <a href="/services" class="btn btn-book">Voir tous les services →</a>
      <a href="/reservation" class="btn btn-outline-dark ms-3">Réserver →</a>
    </div>
  </div>
</section>

<!-- VIDEO SECTION -->
<section class="video-section">
  <video autoplay muted loop class="video-bg" id="bgVideo">
    <source src="/images/WhatsApp Video 2026-02-25 at 21.47.59.mp4" type="video/mp4">
  </video>
  <div class="video-overlay"></div>
  <div class="video-content text-center">
    <button class="video-play-btn" onclick="toggleVideo()">
      <i class="bi bi-play-fill" id="playIcon"></i>
    </button>
    <p class="video-label mt-2">Regarder notre vidéo</p>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="testimonials-section py-5">
  <div class="container">
    <p class="section-pre text-center gold">témoignages</p>
    <h2 class="section-title text-center mb-5">CE QUE DISENT NOS CLIENTES</h2>
    <div class="row g-4 animate-stagger">
      <% if (temoignages && temoignages.length > 0) { %>
        <% temoignages.forEach(function(t) { %>
        <div class="col-md-6 col-lg-3">
          <div class="testimonial-card">
            <div class="stars mb-2">
              <% for(let i=0; i<t.note; i++) { %><i class="bi bi-star-fill text-warning"></i><% } %>
            </div>
            <p class="testimonial-text">"<%= t.texte %>"</p>
            <div class="testimonial-author mt-3">
              <div class="author-avatar"><%= t.nom.charAt(0) %></div>
              <span class="author-name"><%= t.nom %></span>
            </div>
          </div>
        </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<!-- BOOKING CTA -->
<section class="booking-cta-section">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-6">
        <img src="/images/nail-15.jpg" alt="Book Manicure" class="img-fluid rounded booking-img" onerror="this.onerror=null; this.src='/images/nail-01.jpg'">
      </div>
      <div class="col-md-6">
        <div class="booking-text-box">
          <p class="section-pre gold">rendez-vous</p>
          <h2 class="section-title">PRENEZ RDV<br>POUR UNE MANUCURE</h2>
          <p class="section-text">Réservez votre séance en quelques clics. Nos expertes vous accueillent du lundi au samedi pour vous offrir une expérience beauté inoubliable.</p>
          <a href="/reservation" class="btn btn-dark mt-3">Réserver maintenant →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- GALERIE PREVIEW -->
<section class="gallery-preview-section py-5">
  <div class="container">
    <p class="section-pre text-center gold">galerie</p>
    <h2 class="section-title text-center mb-4">NOS RÉALISATIONS</h2>
    <div class="row g-2 animate-stagger">
      <% const galImages = ['nail-01.jpg','nail-05.jpg','nail-08.jpg','nail-12.jpg','nail-16.jpg','nail-20.jpg','nail-25.jpg','nail-30.jpg','nail-35.jpg']; %>
      <% galImages.forEach(function(img) { %>
      <div class="col-6 col-md-4 col-lg-3">
        <div class="gallery-thumb-wrap">
          <img src="/images/<%= img %>" onerror="this.onerror=null; this.src='/images/nail-01.jpg'"  alt="Nail Art" class="img-fluid gallery-thumb">
          <div class="gallery-thumb-overlay">
            <i class="bi bi-zoom-in"></i>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <div class="text-center mt-4">
      <a href="/galerie" class="btn btn-outline-dark">Voir toute la galerie →</a>
    </div>
  </div>
</section>

<!-- BLOG PREVIEW -->
<section class="blog-preview-section py-5 bg-light">
  <div class="container">
    <p class="section-pre text-center gold">articles</p>
    <h2 class="section-title text-center mb-5">NOTRE BLOG</h2>
    <div class="row g-4 animate-stagger">
      <% if (articles && articles.length > 0) { %>
        <% articles.forEach(function(a) { %>
        <div class="col-md-4">
          <div class="blog-card h-100">
            <div class="blog-card-img-wrap">
              <img src="/images/<%= a.image || 'nail-01.jpg' %>" onerror="this.onerror=null; this.src='/images/nail-01.jpg'"  alt="<%= a.titre %>" class="blog-card-img">
            </div>
            <div class="blog-card-body p-3">
              <span class="blog-category"><%= a.categorie || 'MANICURE' %></span>
              <h5 class="blog-title mt-2"><a href="/blog/<%= a.id %>"><%= a.titre %></a></h5>
              <div class="blog-meta">
                <small class="text-muted"><i class="bi bi-calendar3 me-1"></i><%= new Date(a.created_at).toLocaleDateString('fr-FR') %></small>
                <small class="text-muted ms-2"><i class="bi bi-eye me-1"></i><%= a.vues %></small>
                <small class="text-muted ms-2"><i class="bi bi-chat me-1"></i><%= a.commentaires %></small>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      <% } %>
    </div>
    <div class="text-center mt-4">
      <a href="/blog" class="btn btn-outline-dark">Voir tous les articles →</a>
    </div>
  </div>
</section>

<!-- BRANDS SECTION -->
<section class="brands-section py-4">
  <div class="container">
    <div class="row align-items-center justify-content-center g-4 text-center">
      <div class="col-6 col-md-2"><div class="brand-item">rosé <small>BEVERAGE</small></div></div>
      <div class="col-6 col-md-2"><div class="brand-item">nf <small>Photography</small></div></div>
      <div class="col-6 col-md-2"><div class="brand-item brand-circle">A</div></div>
      <div class="col-6 col-md-2"><div class="brand-item">🌿 NATURAL</div></div>
      <div class="col-6 col-md-2"><div class="brand-item">AW <small>Photography</small></div></div>
      <div class="col-6 col-md-2"><div class="brand-item brand-square">M</div></div>
    </div>
  </div>
</section>

<!-- FLOATING WHATSAPP -->
<a href="https://wa.me/221782478147" class="float-whatsapp" title="WhatsApp Khoyane Beauty" target="_blank">
  <i class="bi bi-whatsapp"></i>
</a>

<%- include('partials/footer') %>
