<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connexion Admin — Khoyane Beauty</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0; min-height: 100vh;
      background: linear-gradient(135deg, #1a0a2e 0%, #2d1354 50%, #1a0a2e 100%);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Jost', sans-serif;
    }
    .login-card {
      background: #fff;
      border-radius: 4px;
      padding: 3rem 2.5rem;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 30px 80px rgba(0,0,0,0.4);
    }
    .brand-title {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-style: italic;
      letter-spacing: 4px;
      color: #1a0a2e;
    }
    .brand-sub {
      font-size: 9px;
      letter-spacing: 6px;
      color: #9b59b6;
      text-transform: uppercase;
      display: block;
      margin-top: -4px;
    }
    .divider { border-top: 1px solid #f0e6f6; margin: 1.5rem 0; }
    .form-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: #888; font-weight: 500; }
    .form-control {
      border: none;
      border-bottom: 1.5px solid #e0d0ee;
      border-radius: 0;
      padding: 0.6rem 0;
      font-size: 14px;
      font-family: 'Jost', sans-serif;
      background: transparent;
    }
    .form-control:focus {
      box-shadow: none;
      border-bottom-color: #9b59b6;
      background: transparent;
    }
    .btn-login {
      background: #1a0a2e;
      color: #fff;
      border: none;
      border-radius: 0;
      padding: 12px 32px;
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      width: 100%;
      transition: background 0.25s;
      font-family: 'Jost', sans-serif;
      font-weight: 500;
    }
    .btn-login:hover { background: #9b59b6; color: #fff; }
    .alert-error {
      background: #ffeef0;
      border-left: 3px solid #e74c3c;
      border-radius: 0;
      padding: 0.75rem 1rem;
      font-size: 12px;
      color: #c0392b;
    }
    .hint-box {
      background: #f8f4fc;
      border-radius: 4px;
      padding: 0.75rem 1rem;
      font-size: 11px;
      color: #9b59b6;
      letter-spacing: 0.3px;
    }
    .hint-box strong { color: #1a0a2e; }
    .back-link { color: #aaa; font-size: 11px; letter-spacing: 1px; text-transform: uppercase; text-decoration: none; }
    .back-link:hover { color: #9b59b6; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="text-center mb-4">
      <div class="brand-title">Khoyane</div>
      <span class="brand-sub">Beauty · Admin</span>
    </div>

    <% if (error) { %>
    <div class="alert-error mb-3">
      <i class="bi bi-exclamation-circle me-1"></i> <%= error %>
    </div>
    <% } %>

    <div class="divider"></div>

    <form action="/admin/login" method="POST">
      <div class="mb-4">
        <label class="form-label">Adresse e-mail</label>
        <input type="email" name="email" class="form-control"
          placeholder="admin@khoyanebeauty.com" required
          value="<%= process.env.ADMIN_EMAIL || 'admin@khoyanebeauty.com' %>">
      </div>
      <div class="mb-4">
        <label class="form-label">Mot de passe</label>
        <input type="password" name="password" class="form-control"
          placeholder="••••••••" required>
      </div>

      <button type="submit" class="btn-login mt-2">Se connecter →</button>
    </form>

    <div class="divider"></div>

    <div class="hint-box mb-3">
      <strong>Identifiants par défaut :</strong><br>
      Email : <strong><%= process.env.ADMIN_EMAIL || 'admin@khoyanebeauty.com' %></strong><br>
      Mot de passe : <strong><%= process.env.ADMIN_PASSWORD || 'admin123' %></strong><br>
      <small class="text-muted d-block mt-1">Modifiez ces valeurs dans le fichier <code>.env</code></small>
    </div>

    <div class="text-center">
      <a href="/" class="back-link">← Retour au site</a>
    </div>
  </div>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
</body>
</html>
