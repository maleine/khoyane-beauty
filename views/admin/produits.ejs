<%- include('layout-top') %>

<% if (success) { %>
<div class="alert mb-4" style="background:#d4edda;border-left:4px solid #28a745;border-radius:4px;padding:12px 16px;font-size:13px;color:#155724;">✓ <%= success %></div>
<% } %>
<% if (error) { %>
<div class="alert mb-4" style="background:#f8d7da;border-left:4px solid #dc3545;border-radius:4px;padding:12px 16px;font-size:13px;color:#721c24;">⚠ <%= error %></div>
<% } %>

<div class="row g-4">

  <!-- ═══ FORMULAIRE AJOUT ═══ -->
  <div class="col-lg-4">
    <div class="bg-white rounded-3 p-4" style="position:sticky;top:80px;">
      <h6 style="font-family:'Playfair Display',serif;font-style:italic;font-size:1.1rem;margin-bottom:1.5rem;">
        Ajouter un produit
      </h6>

      <form action="/admin/produits" method="POST" enctype="multipart/form-data">

        <div class="mb-3">
          <label class="form-label" style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#888;">Nom du produit *</label>
          <input type="text" name="nom" class="form-control" required placeholder="ex: Vernis Semi-Permanent">
        </div>

        <div class="mb-3">
          <label class="form-label" style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#888;">Description</label>
          <textarea name="description" class="form-control" rows="2" placeholder="Courte description..."></textarea>
        </div>

        <div class="row g-2 mb-3">
          <div class="col-6">
            <label class="form-label" style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#888;">Prix (FCFA) *</label>
            <input type="number" name="prix" class="form-control" step="0.01" required placeholder="5000">
          </div>
          <div class="col-6">
            <label class="form-label" style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#888;">Stock</label>
            <input type="number" name="stock" class="form-control" value="0" min="0">
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label" style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#888;">Catégorie *</label>
          <select name="categorie" class="form-select" required>
            <option value="vernis">Vernis</option>
            <option value="soins">Soins</option>
            <option value="outils">Outils</option>
            <option value="deco">Décorations</option>
            <option value="beaute">Beauté</option>
          </select>
        </div>

        <!-- Upload image -->
        <div class="mb-4">
          <label class="form-label" style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#888;">Image du produit</label>
          <div id="prodDropZone" onclick="document.getElementById('prodImageUpload').click()"
            style="border:2px dashed #e0d0ee;border-radius:8px;padding:1.5rem;text-align:center;cursor:pointer;transition:all 0.2s;background:#fdf9ff;">
            <div id="prodDropContent">
              <div style="font-size:2rem;margin-bottom:8px;">📦</div>
              <div style="font-size:12px;color:#9b59b6;font-weight:500;">Cliquez ou glissez une image</div>
              <div style="font-size:10px;color:#aaa;margin-top:4px;">JPG, PNG, WEBP · Max 5MB</div>
            </div>
            <img id="prodPreviewImg" src="" alt="" style="display:none;max-height:120px;border-radius:6px;object-fit:cover;" onerror="this.onerror=null; this.src='/images/nail-01.jpg'">
          </div>
          <input type="file" id="prodImageUpload" name="image_upload" accept="image/*" style="display:none" onchange="previewProd(this)">
          <div style="display:flex;align-items:center;gap:8px;margin-top:10px;">
            <div style="flex:1;height:1px;background:#eee;"></div>
            <span style="font-size:10px;color:#aaa;letter-spacing:1px;">OU fichier existant</span>
            <div style="flex:1;height:1px;background:#eee;"></div>
          </div>
          <input type="text" name="image" class="form-control mt-2" placeholder="nail-01.jpg" style="font-size:11px;" id="prodImageName">
        </div>

        <button type="submit" class="btn w-100" style="background:#1a0a2e;color:#fff;border-radius:0;font-size:11px;letter-spacing:2px;text-transform:uppercase;padding:12px;">
          ＋ Ajouter le produit
        </button>
      </form>
    </div>
  </div>

  <!-- ═══ LISTE PRODUITS ═══ -->
  <div class="col-lg-8">
    <div class="bg-white rounded-3 p-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h6 style="font-family:'Playfair Display',serif;font-style:italic;font-size:1.1rem;margin:0;">
          Produits (<%= produits ? produits.length : 0 %>)
        </h6>
        <form action="/admin/produits/dedup" method="POST" onsubmit="return confirm('Supprimer les doublons ?')">
          <button type="submit" class="btn btn-sm btn-outline-warning" style="font-size:10px;letter-spacing:1px;border-radius:0;">
            <i class="bi bi-scissors me-1"></i>Supprimer doublons
          </button>
        </form>
      </div>

      <div class="table-responsive">
        <table class="table align-middle" style="font-size:13px;">
          <thead>
            <tr style="border-bottom:2px solid #f0e6f6;">
              <th style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#888;font-weight:500;padding-bottom:12px;">Produit</th>
              <th style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#888;font-weight:500;padding-bottom:12px;">Catégorie</th>
              <th style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#888;font-weight:500;padding-bottom:12px;">Prix</th>
              <th style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#888;font-weight:500;padding-bottom:12px;">Stock</th>
              <th style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#888;font-weight:500;padding-bottom:12px;">Statut</th>
              <th style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#888;font-weight:500;padding-bottom:12px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (produits && produits.length > 0) { %>
              <% produits.forEach(function(p) { %>
              <tr style="border-bottom:1px solid #f9f3fd;transition:background 0.2s;"
                  onmouseover="this.style.background='#fdf8ff'" onmouseout="this.style.background=''">
                <td>
                  <div class="d-flex align-items-center gap-3">
                    <img src="/images/<%= p.image || 'nail-01.jpg' %>" onerror="this.onerror=null; this.src='/images/nail-01.jpg'"  alt=""
                      style="width:52px;height:52px;object-fit:cover;border-radius:8px;flex-shrink:0;"
                      onerror="this.src='/images/nail-01.jpg'">
                    <div>
                      <div style="font-weight:600;color:#1a0a2e;font-size:13px;"><%= p.nom %></div>
                      <div style="font-size:11px;color:#aaa;">
                        <%= p.description ? p.description.substring(0,40)+(p.description.length>40?'…':'') : '—' %>
                      </div>
                    </div>
                  </div>
                </td>
                <td>
                  <span style="background:#f3e5f5;color:#9b59b6;font-size:10px;letter-spacing:1px;padding:3px 10px;border-radius:20px;text-transform:uppercase;">
                    <%= p.categorie %>
                  </span>
                </td>
                <td style="font-weight:600;color:#1a0a2e;font-family:'Playfair Display',serif;font-size:1rem;">
                  <%= Number(p.prix).toLocaleString('fr-FR') %> <small style="font-size:9px;color:#aaa;font-family:'Jost',sans-serif;">FCFA</small>
                </td>
                <td>
                  <span style="font-size:12px;color:<%= p.stock > 0 ? '#00b894' : '#e74c3c' %>;">
                    <i class="bi bi-circle-fill me-1" style="font-size:7px;"></i><%= p.stock %>
                  </span>
                </td>
                <td>
                  <% if (p.actif) { %>
                    <span style="background:#d4edda;color:#155724;font-size:10px;padding:3px 10px;border-radius:20px;">Visible</span>
                  <% } else { %>
                    <span style="background:#f8d7da;color:#721c24;font-size:10px;padding:3px 10px;border-radius:20px;">Masqué</span>
                  <% } %>
                </td>
                <td>
                  <div class="d-flex gap-1">
                    <form action="/admin/produits/<%= p.id %>/toggle" method="POST">
                      <button type="submit" class="btn btn-sm" title="<%= p.actif ? 'Masquer' : 'Afficher' %>"
                        style="background:#f0e8fd;color:#9b59b6;border:none;border-radius:50%;width:30px;height:30px;padding:0;">
                        <i class="bi bi-<%= p.actif ? 'eye-slash' : 'eye' %>"></i>
                      </button>
                    </form>
                    <form action="/admin/produits/<%= p.id %>/delete" method="POST"
                      onsubmit="return confirm('Supprimer ce produit ?')">
                      <button type="submit" style="background:#fdf0f0;color:#e74c3c;border:none;border-radius:50%;width:30px;height:30px;padding:0;cursor:pointer;">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="6" class="text-center py-5 text-muted">Aucun produit. Ajoutez-en un ci-contre.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
function previewProd(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      document.getElementById('prodPreviewImg').src = e.target.result;
      document.getElementById('prodPreviewImg').style.display = 'block';
      document.getElementById('prodDropContent').style.display = 'none';
      document.getElementById('prodDropZone').style.borderColor = '#9b59b6';
      document.getElementById('prodImageName').value = '';
    };
    reader.readAsDataURL(input.files[0]);
  }
}
const pz = document.getElementById('prodDropZone');
pz.addEventListener('dragover', e => { e.preventDefault(); pz.style.borderColor='#9b59b6'; pz.style.background='#f9f4ff'; });
pz.addEventListener('dragleave', () => { pz.style.borderColor='#e0d0ee'; pz.style.background='#fdf9ff'; });
pz.addEventListener('drop', e => {
  e.preventDefault();
  document.getElementById('prodImageUpload').files = e.dataTransfer.files;
  previewProd(document.getElementById('prodImageUpload'));
});
</script>

<%- include('layout-bottom') %>
